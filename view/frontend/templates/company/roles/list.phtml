<?php
/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Shubo\CompanyAccount\ViewModel\CompanyRoles $viewModel */
/** @var \Magento\Framework\Escaper $escaper */
$viewModel = $block->getData('view_model');
$roles = $viewModel->getRoles();
$permissions = $viewModel->getAvailablePermissions();
?>

<div class="container mx-auto px-4 py-6" x-data="{ showRoleModal: false, editRole: null }">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold"><?= $escaper->escapeHtml(__('Company Roles')) ?></h1>
        <button @click="editRole = null; showRoleModal = true"
                class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm">
            <?= $escaper->escapeHtml(__('Create Role')) ?>
        </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <?php foreach ($roles as $role): ?>
        <div class="bg-white rounded-lg shadow p-4">
            <div class="flex justify-between items-start">
                <h3 class="font-semibold"><?= $escaper->escapeHtml($role['role_name']) ?></h3>
                <?php if ($role['is_default']): ?>
                    <span class="px-2 py-0.5 bg-blue-100 text-blue-700 text-xs rounded"><?= $escaper->escapeHtml(__('Default')) ?></span>
                <?php endif; ?>
            </div>
            <?php if ($role['description']): ?>
                <p class="text-sm text-gray-500 mt-1"><?= $escaper->escapeHtml($role['description']) ?></p>
            <?php endif; ?>
            <div class="mt-3 flex gap-2">
                <a href="<?= $escaper->escapeUrl($block->getUrl('company/account/roles_delete', ['role_id' => $role['role_id']])) ?>"
                   class="text-red-600 text-sm hover:underline"
                   onclick="return confirm('<?= $escaper->escapeJs(__('Delete this role?')) ?>')">
                    <?= $escaper->escapeHtml(__('Delete')) ?>
                </a>
            </div>
        </div>
        <?php endforeach; ?>
    </div>

    <?php if (empty($roles)): ?>
    <p class="text-gray-500 text-center py-8"><?= $escaper->escapeHtml(__('No roles created yet.')) ?></p>
    <?php endif; ?>

    <!-- Create Role Modal -->
    <div x-show="showRoleModal" x-cloak class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50">
        <div class="bg-white rounded-lg shadow-xl p-6 w-full max-w-md" @click.away="showRoleModal = false">
            <h2 class="text-lg font-semibold mb-4"><?= $escaper->escapeHtml(__('Create Role')) ?></h2>
            <form action="<?= $escaper->escapeUrl($block->getUrl('company/account/roles_save')) ?>" method="post">
                <?= $block->getBlockHtml('formkey') ?>
                <div class="space-y-3">
                    <input type="text" name="role_name" required placeholder="<?= $escaper->escapeHtmlAttr(__('Role Name')) ?>" class="border rounded px-3 py-2 w-full">
                    <textarea name="description" placeholder="<?= $escaper->escapeHtmlAttr(__('Description (optional)')) ?>" class="border rounded px-3 py-2 w-full" rows="2"></textarea>
                </div>
                <div class="flex justify-end gap-3 mt-4">
                    <button type="button" @click="showRoleModal = false" class="px-4 py-2 border rounded"><?= $escaper->escapeHtml(__('Cancel')) ?></button>
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700"><?= $escaper->escapeHtml(__('Save Role')) ?></button>
                </div>
            </form>
        </div>
    </div>
</div>
