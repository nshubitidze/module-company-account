<script>
    function companyRegistration() {
        return {
            step: 0,
            steps: ['<?= $escaper->escapeJs(__('Company')) ?>', '<?= $escaper->escapeJs(__('Address')) ?>', '<?= $escaper->escapeJs(__('Account')) ?>', '<?= $escaper->escapeJs(__('Review')) ?>'],
            submitting: false,
            regions: <?= /* @noEscape */ $viewModel->getRegionsJson() ?>,
            availableRegions: [],
            formData: {
                company_name: '',
                company_email: '',
                legal_name: '',
                vat_tax_id: '',
                phone: '',
                website: '',
                street_line1: '',
                street_line2: '',
                city: '',
                postcode: '',
                country_id: '',
                region: '',
                region_id: '',
                admin_firstname: '',
                admin_lastname: '',
                admin_email: '',
                admin_password: '',
                admin_password_confirm: ''
            },

            nextStep() {
                if (this.validateStep()) {
                    this.step++;
                }
            },

            validateStep() {
                if (this.step === 0) {
                    return this.formData.company_name && this.formData.company_email;
                }
                if (this.step === 1) {
                    return this.formData.street_line1 && this.formData.city && this.formData.postcode && this.formData.country_id;
                }
                if (this.step === 2) {
                    return this.formData.admin_firstname && this.formData.admin_lastname &&
                           this.formData.admin_email && this.formData.admin_password &&
                           this.formData.admin_password === this.formData.admin_password_confirm &&
                           this.formData.admin_password.length >= 8;
                }
                return true;
            },

            updateRegions() {
                this.availableRegions = this.regions[this.formData.country_id] || [];
                this.formData.region_id = '';
                this.formData.region = '';
            },

            submitForm(event) {
                if (!this.validateStep()) {
                    event.preventDefault();
                    return;
                }
                this.submitting = true;
            }
        }
    }
</script>
