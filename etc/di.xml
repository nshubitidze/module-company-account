<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Data Interface Preferences -->
    <preference for="Shubo\CompanyAccount\Api\Data\CompanyInterface"
                type="Shubo\CompanyAccount\Model\Company"/>
    <preference for="Shubo\CompanyAccount\Api\Data\CompanyAddressInterface"
                type="Shubo\CompanyAccount\Model\CompanyAddress"/>
    <preference for="Shubo\CompanyAccount\Api\Data\CompanyTeamInterface"
                type="Shubo\CompanyAccount\Model\CompanyTeam"/>
    <preference for="Shubo\CompanyAccount\Api\Data\CompanyRoleInterface"
                type="Shubo\CompanyAccount\Model\CompanyRole"/>
    <preference for="Shubo\CompanyAccount\Api\Data\CompanyUserInterface"
                type="Shubo\CompanyAccount\Model\CompanyUser"/>
    <preference for="Shubo\CompanyAccount\Api\Data\CompanySearchResultsInterface"
                type="Magento\Framework\Api\SearchResults"/>

    <!-- Repository Preferences -->
    <preference for="Shubo\CompanyAccount\Api\CompanyRepositoryInterface"
                type="Shubo\CompanyAccount\Model\CompanyRepository"/>
    <preference for="Shubo\CompanyAccount\Api\CompanyAddressRepositoryInterface"
                type="Shubo\CompanyAccount\Model\CompanyAddressRepository"/>
    <preference for="Shubo\CompanyAccount\Api\CompanyTeamRepositoryInterface"
                type="Shubo\CompanyAccount\Model\CompanyTeamRepository"/>
    <preference for="Shubo\CompanyAccount\Api\CompanyRoleRepositoryInterface"
                type="Shubo\CompanyAccount\Model\CompanyRoleRepository"/>
    <preference for="Shubo\CompanyAccount\Api\CompanyUserRepositoryInterface"
                type="Shubo\CompanyAccount\Model\CompanyUserRepository"/>

    <!-- Management Preferences -->
    <preference for="Shubo\CompanyAccount\Api\CompanyManagementInterface"
                type="Shubo\CompanyAccount\Model\CompanyManagement"/>

    <!-- Plugins -->
    <type name="Magento\Customer\Api\CustomerRepositoryInterface">
        <plugin name="shubo_company_customer_data"
                type="Shubo\CompanyAccount\Plugin\Customer\AddCompanyDataToCustomerPlugin"
                sortOrder="10"/>
    </type>

    <type name="Magento\Sales\Api\OrderRepositoryInterface">
        <plugin name="shubo_company_order_data"
                type="Shubo\CompanyAccount\Plugin\Checkout\AddCompanyInfoToOrderPlugin"
                sortOrder="10"/>
    </type>

</config>
