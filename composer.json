{
    "name": "shubo/module-company-account",
    "description": "Free, open-source B2B Company Accounts for Magento 2 Open Source. Create company hierarchies, manage users with roles and permissions. Hyva-native. Foundation for Shubo B2B Suite.",
    "type": "magento2-module",
    "version": "1.0.0",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "magento/framework": ">=103.0.0",
        "magento/module-customer": ">=103.0.0",
        "magento/module-store": ">=101.0.0",
        "magento/module-email": ">=101.0.0",
        "magento/module-ui": ">=101.0.0",
        "magento/module-backend": ">=102.0.0",
        "magento/module-authorization": ">=100.4.0",
        "magento/module-directory": ">=100.4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "magento/magento-coding-standard": ">=30",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Shubo\\CompanyAccount\\": ""
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.magento.com/"
        }
    ],
    "keywords": [
        "magento2",
        "b2b",
        "company-accounts",
        "hyva",
        "open-source"
    ],
    "authors": [
        {
            "name": "Shubo",
            "homepage": "https://shubo.com"
        }
    ],
    "support": {
        "issues": "https://github.com/nshubitidze/module-company-account/issues",
        "source": "https://github.com/nshubitidze/module-company-account"
    }
}
